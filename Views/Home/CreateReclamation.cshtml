@model Nursari.Models.Reclamation
@{
    ViewData["Title"] = "Input Target Reklamasi";
}

<div class="view-header">
    <div class="view-title-wrap">
        <h1>Input Target Reklamasi</h1>
        <p>Penyusunan target luasan (Hektar) dan target jumlah bibit ditanam per tahun</p>
    </div>
    <div>
        <a class="btn btn-login" asp-action="Reclamation" style="background: var(--text-light); color: white; display: inline-flex; align-items: center; gap: 5px;">
            <i class="fa-solid fa-arrow-left"></i> Kembali
        </a>
    </div>
</div>

<div class="dashboard-card col-8" style="margin: 0 auto; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border-radius: 12px; border: 1px solid var(--border-color); overflow: hidden;">
    <div class="card-header" style="background: linear-gradient(135deg, var(--primary-green), #10b981); color: white; padding: 20px;">
        <span class="card-title" style="color: white; font-weight: bold;"><i class="fa-solid fa-bullseye"></i> Form Target Evaluasi Reklamasi Lahan</span>
    </div>

    <form asp-action="CreateReclamation" method="post" style="padding: 25px; display: flex; flex-direction: column; gap: 20px;">
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
            <!-- Reclamation Area -->
            <div style="display: flex; flex-direction: column; gap: 8px;">
                <label for="ReclamationArea" style="font-size: 13px; font-weight: 600; color: var(--text-main);">Nama Area Reklamasi <span style="color: red;">*</span></label>
                <input type="text" id="ReclamationArea" asp-for="ReclamationArea" class="form-control" placeholder="Contoh: IPDT2 Blok R" required style="width: 100%; border: 1px solid var(--border-color); border-radius: 6px; padding: 10px;" />
            </div>

            <!-- Area Size -->
            <div style="display: flex; flex-direction: column; gap: 8px;">
                <label for="AreaSize" style="font-size: 13px; font-weight: 600; color: var(--text-main);">Luas Area (Hektar) <span style="color: red;">*</span></label>
                <input type="number" step="0.01" id="AreaSize" asp-for="AreaSize" class="form-control" placeholder="0.00" required style="width: 100%; border: 1px solid var(--border-color); border-radius: 6px; padding: 10px;" />
            </div>

            <!-- Year -->
            <div style="display: flex; flex-direction: column; gap: 8px;">
                <label for="Year" style="font-size: 13px; font-weight: 600; color: var(--text-main);">Tahun Target <span style="color: red;">*</span></label>
                <input type="number" id="Year" asp-for="Year" class="form-control" placeholder="2026" required style="width: 100%; border: 1px solid var(--border-color); border-radius: 6px; padding: 10px;" />
            </div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;">
            <!-- Target Seedlings -->
            <div style="display: flex; flex-direction: column; gap: 8px;">
                <label for="TargetSeedlings" style="font-size: 13px; font-weight: 600; color: var(--text-main);">Target Jumlah Bibit <span style="color: red;">*</span></label>
                <input type="number" id="TargetSeedlings" asp-for="TargetSeedlings" class="form-control" placeholder="0" min="1" required style="width: 100%; border: 1px solid var(--border-color); border-radius: 6px; padding: 10px;" />
            </div>

            <!-- Actual Seedlings -->
            <div style="display: flex; flex-direction: column; gap: 8px;">
                <label for="ActualSeedlings" style="font-size: 13px; font-weight: 600; color: var(--text-main);">Bibit Teralokasi Aktual <span style="color: red;">*</span></label>
                <input type="number" id="ActualSeedlings" asp-for="ActualSeedlings" class="form-control" placeholder="0" min="0" required style="width: 100%; border: 1px solid var(--border-color); border-radius: 6px; padding: 10px;" />
            </div>
        </div>

        <!-- Buttons -->
        <div style="display: flex; justify-content: flex-end; gap: 15px; border-top: 1px solid var(--border-color); padding-top: 20px; margin-top: 10px;">
            <a class="btn" asp-action="Reclamation" style="background: #ef4444; color: white;">Batal</a>
            <button type="submit" class="btn btn-primary">Simpan Target</button>
        </div>
    </form>
</div>
