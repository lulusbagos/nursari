@model List<Nursari.Models.Ledger>
@{
    ViewData["Title"] = "Transaction Ledger";
}

<div class="view-header">
    <div class="view-title-wrap">
        <h1>Transaction Ledger</h1>
        <p>Buku besar mutasi keluar, masuk, penyusutan, dan penyesuaian stok bibit</p>
    </div>
</div>

<div class="dashboard-card col-12">
    <div class="card-header">
        <span class="card-title">Log Transaksi Mutasi Bibit</span>
    </div>
    <div class="table-wrapper">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Ref ID</th>
                    <th>Tanggal</th>
                    <th>Batch ID</th>
                    <th>Tipe Mutasi</th>
                    <th style="text-align: right;">Masuk (+)</th>
                    <th style="text-align: right;">Keluar (-)</th>
                    <th style="text-align: right;">Saldo</th>
                    <th>Keterangan</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="font-weight: 600; font-family: monospace;">@item.TransactionNumber</td>
                        <td>@item.Date</td>
                        <td style="font-family: monospace;">@item.Batch</td>
                        <td>
                            @if (item.Type == "Receipt")
                            {
                                <span class="badge green">Receipt</span>
                            }
                            else if (item.Type == "Planting")
                            {
                                <span class="badge blue">Planting</span>
                            }
                            else if (item.Type == "Mortality")
                            {
                                <span class="badge red">Mortality</span>
                            }
                            else
                            {
                                <span class="badge yellow">@item.Type</span>
                            }
                        </td>
                        <td style="text-align: right; color: var(--success-green); font-weight: bold;">
                            @(item.QtyIn > 0 ? $"+{item.QtyIn:N0}" : "-")
                        </td>
                        <td style="text-align: right; color: var(--critical-red); font-weight: bold;">
                            @(item.QtyOut > 0 ? $"-{item.QtyOut:N0}" : "-")
                        </td>
                        <td style="text-align: right; font-weight: bold;">@item.Balance.ToString("N0")</td>
                        <td style="font-size: 12px; color: var(--text-light);">@item.Remarks</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
